# ===================================
# OTC Platform - Frontend Configuration
# ===================================

# -----------------
# API Configuration
# -----------------
# Backend API URL
# Development: http://localhost:3001
# Production: https://your-app.up.railway.app (Update after Railway deployment)
NEXT_PUBLIC_API_URL=http://localhost:3001

# -----------------
# Environment
# -----------------
NODE_ENV=development

# -----------------
# Production Settings
# -----------------
# Uncomment and configure these for production deployment on Vercel:

# Backend API URL (Get this from Railway after backend deployment)
# NEXT_PUBLIC_API_URL=https://your-railway-app.up.railway.app

# Disable Next.js telemetry in production (optional)
# NEXT_TELEMETRY_DISABLED=1

# -----------------
# Optional: Analytics and Monitoring
# -----------------
# Google Analytics, Mixpanel, or custom analytics
# NEXT_PUBLIC_ANALYTICS_ID=

# Sentry for error tracking
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# -----------------
# Optional: Feature Flags
# -----------------
# Enable/disable features without code changes
# NEXT_PUBLIC_ENABLE_ANALYTICS=false
# NEXT_PUBLIC_MAINTENANCE_MODE=false
# NEXT_PUBLIC_DEBUG_MODE=false

# -----------------
# Deployment Instructions
# -----------------
# 1. Copy this file to .env.local for local development
# 2. Update NEXT_PUBLIC_API_URL with your Railway backend URL for production
# 3. Set environment variables in Vercel dashboard for production deployment
# 4. See VERCEL_DEPLOYMENT.md for complete deployment guide
